{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",
      "Bash(npm test:*)",
      "Bash(jq:*)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "agent-browser@agent-browser-marketplace": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "agent-browser-marketplace": {
      "source": {
        "source": "github",
        "repo": "vercel-labs/agent-browser",
        "path": ".claude-plugin/marketplace.json"
      }
    }
  }
}
