{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "cleanupPeriodDays": 14,
  "alwaysThinkingEnabled": true,
  "spinnerTipsEnabled": false,
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "USE_BUILTIN_RIPGREP": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",
      "Bash(npm test:*)",
      "Bash(jq:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:arxiv.org)",
      "Read(/Users/jack.jennings/.claude/projects/*)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "agent-browser@agent-browser": true
  }
}
