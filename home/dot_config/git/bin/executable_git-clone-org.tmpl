#!/bin/bash
# Usage: git clone-org [-n] <org>
#
# Clones up to 50 of the most recently pushed, non-archived repositories
# from the given GitHub organization into ~/{{ .code_directory }}/<org>.
#
# Options:
#   -n, --dry-run  Print repos that would be cloned without cloning them
#
# Example:
#   git clone-org my-org
#   git clone-org -n my-org

if ! gh auth status 2>&1 | grep -q 'read:org'; then
    echo "Missing 'read:org' scope, refreshing token..." >&2
    gh auth refresh -s read:org
fi

dry_run=false
if [[ "$1" == "-n" || "$1" == "--dry-run" ]]; then
    dry_run=true
    shift
fi

org="${1}"
target_dir="${HOME}/{{ .code_directory }}/${org}"
repos=$(gh repo list ${org} --no-archived --json nameWithOwner,pushedAt --jq 'sort_by(.pushedAt) | reverse[:50] | .[].nameWithOwner' -L 5000)

if $dry_run; then
    echo "$repos"
else
    mkdir -p "$target_dir"
    while IFS= read -r repo; do
        dir="${repo#*/}"
        if [[ -d "${target_dir}/${dir}" ]]; then
            echo "Skipping $repo (already exists)"
        else
            gh repo clone "$repo" "${target_dir}/${dir}"
        fi
    done <<< "$repos"
fi
