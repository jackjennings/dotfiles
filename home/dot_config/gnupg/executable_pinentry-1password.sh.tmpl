#!/bin/sh

OP_PGP_PASSPHRASE_ITEM="op://Personal/PGP Passphrase/password"

echo "OK"
while read cmd rest; do
  case "$cmd" in
    \#*)
      echo "OK"
      ;;
    GETPIN)
      if ! PASSPHRASE=$(op read "$OP_PGP_PASSPHRASE_ITEM" --account {{ .onepassword.account_id }} 2>/dev/null); then
        op signin --account {{ .onepassword.account_id }} >/dev/null 2>&1
        PASSPHRASE=$(op read "$OP_PGP_PASSPHRASE_ITEM" --account {{ .onepassword.account_id }})
      fi
      echo "D ${PASSPHRASE}"
      echo "OK"
      ;;
    BYE)
      echo "OK"
      exit 0
      ;;
    *)
      echo "OK"
      ;;
  esac
done
