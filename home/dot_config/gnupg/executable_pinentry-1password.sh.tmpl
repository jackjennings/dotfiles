#!/bin/sh

OP_PGP_PASSPHRASE_ITEM="op://Personal/GPG Master Key Passphrase/password"
OP_ACCOUNT="{{ .onepassword.account_id }}"

op_read_passphrase() {
  op read "$OP_PGP_PASSPHRASE_ITEM" --account "$OP_ACCOUNT"
}

read_passphrase() {
  op_read_passphrase 2>/dev/null && return
  op signin --account "$OP_ACCOUNT" >/dev/null 2>&1
  op_read_passphrase 2>/dev/null
}

echo "OK"
while read cmd rest; do
  case "$cmd" in
    \#*)
      echo "OK"
      ;;
    GETPIN)
      passphrase=$(read_passphrase)
      if [ -z "$passphrase" ]; then
        echo "ERR 67108949 No passphrase available"
      else
        echo "D $passphrase"
        echo "OK"
      fi
      ;;
    BYE)
      echo "OK"
      exit 0
      ;;
    *)
      echo "OK"
      ;;
  esac
done
