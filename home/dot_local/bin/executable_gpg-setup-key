#!/bin/bash

set -e

EMAIL="${1:?Usage: gpg-setup-key <email> [github-username]}"
GITHUB_USERNAME="${2:-}"
GPG_PUBLIC_KEY_FILEPATH=~/.config/.gpg/public-key-$EMAIL
OP_PASSPHRASE_TITLE="PGP Passphrase"
OP_ACCOUNT_ID="EHM4KN6Z35BHJNTV3VFWRLZHUU"

echo "Setting up GnuPG for $EMAIL..." >&2

# Fix permissions on gnupg files to silence warnings
chown -R $(whoami) ~/.gnupg/
find ~/.gnupg -type d -exec chmod 700 {} \;
find ~/.gnupg -type f -exec chmod 600 {} \;

KEY_ID=$(gpg --list-secret-keys --with-colons "$EMAIL" 2>/dev/null \
  | awk -F: '$1 == "sec" { print $5 }' \
  | head -1)

if [[ -z "$KEY_ID" ]]; then
  eval $(op signin --account $OP_ACCOUNT_ID 2>/dev/null)

  OP_PASSPHRASE_ID=$(
    op item list --format=json \
    | jq -r ".[] | select(.title == \"$OP_PASSPHRASE_TITLE\") | .id"
  )

  if [[ ! $OP_PASSPHRASE_ID ]]; then
    OP_PASSPHRASE_ID=$(
      op item template get Password \
      | op item create --vault personal \
                       --title "$OP_PASSPHRASE_TITLE" \
                       --generate-password \
                       --format=json \
                       - \
      | jq -r '.id'
    )
  fi

  PASSPHRASE=$(op item get $OP_PASSPHRASE_ID --fields label=password --reveal)
  NAME=$(git config --global --includes user.name)

  echo "Creating GPG key" >&2

  gpg --batch --generate-key <<EOF
Key-Type: RSA
Key-Length: 4096
Subkey-Type: RSA
Subkey-Length: 4096
Name-Real: $NAME
Name-Email: $EMAIL
Passphrase: $PASSPHRASE
Expire-Date: 0
EOF

  KEY_ID=$(gpg --list-secret-keys --with-colons "$EMAIL" 2>/dev/null \
    | awk -F: '$1 == "sec" { print $5 }' \
    | head -1)

  if [[ -z "$KEY_ID" ]]; then
    echo "Error: GPG key generation failed." >&2
    exit 1
  fi

  rm -f "$GPG_PUBLIC_KEY_FILEPATH"
  mkdir -p $(dirname $GPG_PUBLIC_KEY_FILEPATH)
  gpg --output $GPG_PUBLIC_KEY_FILEPATH --armor --export "$EMAIL"

  echo "Adding GPG key to GitHub" >&2

  CURRENT_GH_USER=$(gh api user --jq .login 2>/dev/null)
  if [[ -n "$GITHUB_USERNAME" && "$GITHUB_USERNAME" != "$CURRENT_GH_USER" ]]; then
    gh auth switch --user "$GITHUB_USERNAME"
    echo "  ... for user $GITHUB_USERNAME"
  fi

  if [[ ! $(gh auth status --active | grep "write:gpg_key") ]]; then
    # This is required in order to get the "Press ENTER" functionality to work
    stty sane
    gh auth refresh --hostname github.com --scopes read:gpg_key,write:gpg_key
  fi

  gh gpg-key add "$GPG_PUBLIC_KEY_FILEPATH"

  if [[ -n "$GITHUB_USERNAME" && "$GITHUB_USERNAME" != "$CURRENT_GH_USER" ]]; then
    gh auth switch --user "$CURRENT_GH_USER"
  fi
else
  echo "GPG key for $EMAIL already exists, skipping key generation." >&2
fi

mkdir -p ~/.config/git
cat > ~/.config/git/gpg-$EMAIL.gitconfig <<EOF
[user]
	signingkey = $KEY_ID
EOF

echo "$KEY_ID"
