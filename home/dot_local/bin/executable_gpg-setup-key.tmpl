#!/bin/bash

set -e

EMAIL="${1:?Usage: gpg-setup-key <email> [github-username]}"
GITHUB_USERNAME="${2:-}"
GPG_PUBLIC_KEY_FILEPATH=~/.config/.gpg/public-key-$EMAIL
OP_ACCOUNT_ID="{{ .onepassword.account_id }}"
DEVICE_UUID=$(system_profiler SPHardwareDataType | awk '/Hardware UUID/ { print $3 }')

echo "Setting up GnuPG for $EMAIL..." >&2

# Fix permissions on gnupg files to silence warnings
chown -R $(whoami) ~/.gnupg/
find ~/.gnupg -type d -exec chmod 700 {} \;
find ~/.gnupg -type f -exec chmod 600 {} \;

KEY_ID=$(gpg --list-secret-keys --with-colons "$EMAIL" 2>/dev/null \
  | awk -F: '$1 == "sec" { print $5 }' \
  | head -1)

if [[ -z "$KEY_ID" ]]; then
  eval $(op signin --account $OP_ACCOUNT_ID 2>/dev/null)

  if ! op document get "GPG Master Key" --account "$OP_ACCOUNT_ID" &>/dev/null; then
    echo "Error: GPG Master Key not found in 1Password." >&2
    echo "Run gpg-master-key first to set up the master key." >&2
    exit 1
  fi

  MASTER_PASS=$(op read "op://Personal/GPG Master Key Passphrase/password" \
      --account "$OP_ACCOUNT_ID")

  echo "Creating GPG subkey for device $DEVICE_UUID..." >&2

  GNUPGHOME_TEMP=$(mktemp -d)
  trap "rm -rf '$GNUPGHOME_TEMP'" EXIT

  op document get "GPG Master Key" --account "$OP_ACCOUNT_ID" \
    | GNUPGHOME="$GNUPGHOME_TEMP" gpg --batch --pinentry-mode loopback \
        --passphrase "$MASTER_PASS" --import

  MASTER_FP=$(GNUPGHOME="$GNUPGHOME_TEMP" gpg --list-secret-keys --with-colons \
    | awk -F: '$1 == "sec" { print $5 }' | head -1)

  GNUPGHOME="$GNUPGHOME_TEMP" gpg --batch --pinentry-mode loopback \
      --passphrase "$MASTER_PASS" \
      --quick-add-key "$MASTER_FP" rsa4096 sign 0

  op item create --vault personal \
      --title "GPG Subkey $DEVICE_UUID" \
      --category Password \
      --generate-password \
      --account "$OP_ACCOUNT_ID"

  DEVICE_PASS=$(op read "op://Personal/GPG Subkey $DEVICE_UUID/password" \
      --account "$OP_ACCOUNT_ID")

  GNUPGHOME="$GNUPGHOME_TEMP" gpg --batch --pinentry-mode loopback \
      --passphrase "$MASTER_PASS" \
      --new-passphrase "$DEVICE_PASS" \
      --quick-change-passphrase "$MASTER_FP"

  SUBKEY_EXPORT=$(GNUPGHOME="$GNUPGHOME_TEMP" gpg --batch --pinentry-mode loopback \
      --passphrase "$DEVICE_PASS" \
      --export-secret-subkeys --armor "$MASTER_FP")

  rm -rf "$GNUPGHOME_TEMP"
  trap - EXIT

  echo "$SUBKEY_EXPORT" | gpg --batch --pinentry-mode loopback \
      --passphrase "$DEVICE_PASS" --import

  KEY_ID=$(gpg --list-secret-keys --with-colons "$EMAIL" 2>/dev/null \
    | awk -F: '$1 == "sec" { print $5 }' \
    | head -1)

  if [[ -z "$KEY_ID" ]]; then
    echo "Error: GPG subkey setup failed." >&2
    exit 1
  fi

  rm -f "$GPG_PUBLIC_KEY_FILEPATH"
  mkdir -p $(dirname $GPG_PUBLIC_KEY_FILEPATH)
  gpg --output $GPG_PUBLIC_KEY_FILEPATH --armor --export "$EMAIL"

  echo "Adding GPG key to GitHub" >&2

  CURRENT_GH_USER=$(gh api user --jq .login 2>/dev/null)
  if [[ -n "$GITHUB_USERNAME" && "$GITHUB_USERNAME" != "$CURRENT_GH_USER" ]]; then
    gh auth switch --user "$GITHUB_USERNAME"
    echo "  ... for user $GITHUB_USERNAME"
  fi

  if [[ ! $(gh auth status --active | grep "write:gpg_key") ]]; then
    # This is required in order to get the "Press ENTER" functionality to work
    stty sane
    gh auth refresh --hostname github.com --scopes read:gpg_key,write:gpg_key
  fi

  gh gpg-key add "$GPG_PUBLIC_KEY_FILEPATH"

  if [[ -n "$GITHUB_USERNAME" && "$GITHUB_USERNAME" != "$CURRENT_GH_USER" ]]; then
    gh auth switch --user "$CURRENT_GH_USER"
  fi
else
  echo "GPG key for $EMAIL already exists, skipping key generation." >&2
fi

mkdir -p ~/.config/git
cat > ~/.config/git/gpg-$EMAIL.gitconfig <<EOF
[user]
	signingkey = $KEY_ID
EOF

echo "$KEY_ID"
