#!/bin/bash

set -e

EMAIL="${1:?Usage: gpg-setup-key <email> [github-username]}"
GITHUB_USERNAME="${2:-}"
OP_ACCOUNT="{{ .onepassword.account_id }}"
PUBLIC_KEY_FILE=~/.config/.gpg/public-key-$EMAIL
MASTER_FINGERPRINT_FILE=~/.config/.gpg/master-fingerprint

echo "Setting up GnuPG for $EMAIL..." >&2

# GPG requires strict permissions on ~/.gnupg or it emits warnings
chown -R $(whoami) ~/.gnupg/
find ~/.gnupg -type d -exec chmod 700 {} \;
find ~/.gnupg -type f -exec chmod 600 {} \;

# Check if a subkey is already present using the cached master fingerprint.
# We look up by fingerprint rather than email because the master key UID may
# not match the email this script was called with.
MASTER_KEY_FINGERPRINT=""
SIGNING_KEY_ID=""
if [[ -f "$MASTER_FINGERPRINT_FILE" ]]; then
  MASTER_KEY_FINGERPRINT=$(cat "$MASTER_FINGERPRINT_FILE")
  SIGNING_KEY_ID=$(gpg --list-secret-keys --with-colons "$MASTER_KEY_FINGERPRINT" 2>/dev/null \
    | awk -F: '$1 == "sec" { print $5 }' | head -1)
fi

if [[ -z "$SIGNING_KEY_ID" ]]; then
  # --- Fetch master key from 1Password ---

  eval $(op signin --account $OP_ACCOUNT 2>/dev/null)

  if ! op document get "GPG Master Key" --account "$OP_ACCOUNT" &>/dev/null; then
    echo "Error: GPG Master Key not found in 1Password." >&2
    echo "Run gpg-master-key first to set up the master key." >&2
    exit 1
  fi

  MASTER_KEY_PASSPHRASE=$(op read "op://Personal/GPG Master Key Passphrase/password" \
      --account "$OP_ACCOUNT")

  echo "Creating GPG subkey..." >&2

  # --- Set up isolated keyring ---

  # Use a temporary GNUPGHOME so the master secret key never touches ~/.gnupg.
  # All master key operations happen here; only the subkey export leaves this directory.
  TEMP_GNUPGHOME=$(mktemp -d)
  trap "rm -rf '$TEMP_GNUPGHOME'" EXIT

  op document get "GPG Master Key" --account "$OP_ACCOUNT" \
    | GNUPGHOME="$TEMP_GNUPGHOME" gpg --batch --pinentry-mode loopback \
        --passphrase "$MASTER_KEY_PASSPHRASE" --import 2>/dev/null

  MASTER_KEY_FINGERPRINT=$(GNUPGHOME="$TEMP_GNUPGHOME" gpg --list-secret-keys --with-colons \
    | awk -F: '/^sec/{found=1} found && /^fpr/{print $10; exit}')

  # --- Generate signing subkey ---

  GNUPGHOME="$TEMP_GNUPGHOME" gpg --batch --pinentry-mode loopback \
      --passphrase "$MASTER_KEY_PASSPHRASE" \
      --quick-add-key "$MASTER_KEY_FINGERPRINT" rsa4096 sign 0

  # Export subkeys only — --export-secret-subkeys omits the master secret key,
  # so importing this into ~/.gnupg leaves the master unrecoverable from this machine.
  EXPORTED_SUBKEYS=$(GNUPGHOME="$TEMP_GNUPGHOME" gpg --batch --pinentry-mode loopback \
      --passphrase "$MASTER_KEY_PASSPHRASE" \
      --export-secret-subkeys --armor "$MASTER_KEY_FINGERPRINT")

  # --- Install subkey into real keyring ---

  rm -rf "$TEMP_GNUPGHOME"
  trap - EXIT

  echo "$EXPORTED_SUBKEYS" | gpg --batch --pinentry-mode loopback \
      --passphrase "$MASTER_KEY_PASSPHRASE" --import 2>/dev/null

  SIGNING_KEY_ID=$(gpg --list-secret-keys --with-colons "$MASTER_KEY_FINGERPRINT" 2>/dev/null \
    | awk -F: '$1 == "sec" { print $5 }' | head -1)

  if [[ -z "$SIGNING_KEY_ID" ]]; then
    echo "Error: GPG subkey setup failed." >&2
    exit 1
  fi

  # Cache fingerprint for future runs so the key-exists check doesn't depend on email UIDs
  mkdir -p $(dirname "$MASTER_FINGERPRINT_FILE")
  echo "$MASTER_KEY_FINGERPRINT" > "$MASTER_FINGERPRINT_FILE"
else
  echo "GPG key already exists, skipping." >&2
fi

# --- Register public key with GitHub ---

CURRENT_GITHUB_USER=$(gh api user --jq .login 2>/dev/null)
if [[ -n "$GITHUB_USERNAME" && "$GITHUB_USERNAME" != "$CURRENT_GITHUB_USER" ]]; then
  gh auth switch --user "$GITHUB_USERNAME" >/dev/null 2>&1
fi

KEY_ID="${MASTER_KEY_FINGERPRINT: -16}"
if ! gh api user/gpg_keys --jq ".[].key_id" 2>/dev/null | grep -qi "^${KEY_ID}$"; then
  if [[ ! -f "$PUBLIC_KEY_FILE" ]]; then
    mkdir -p $(dirname "$PUBLIC_KEY_FILE")
    gpg --output "$PUBLIC_KEY_FILE" --armor --export "$MASTER_KEY_FINGERPRINT"
  fi

  echo "Adding GPG key to GitHub..." >&2

  if [[ ! $(gh auth status --active | grep "write:gpg_key") ]]; then
    # This is required in order to get the "Press ENTER" functionality to work
    stty sane
    gh auth refresh --hostname github.com --scopes read:gpg_key,write:gpg_key
  fi

  gh gpg-key add "$PUBLIC_KEY_FILE"
fi

if [[ -n "$GITHUB_USERNAME" && "$GITHUB_USERNAME" != "$CURRENT_GITHUB_USER" ]]; then
  gh auth switch --user "$CURRENT_GITHUB_USER" >/dev/null 2>&1
fi

# --- Write git signing config ---

mkdir -p ~/.config/git
cat > ~/.config/git/gpg-$EMAIL.gitconfig <<EOF
[user]
	signingkey = $SIGNING_KEY_ID
EOF

echo "$SIGNING_KEY_ID"
