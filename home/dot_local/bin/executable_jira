#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "Usage: jira <which|browse>" >&2
  exit 1
}

get_ticket() {
  if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo "jira: not a git repository" >&2
    exit 1
  fi

  local branch
  branch=$(git rev-parse --abbrev-ref HEAD)

  # Extract ticket from branch format: <username>/<jira-ticket>[optional-suffix]
  local ticket
  ticket=$(echo "$branch" | sed -E 's|^[^/]+/([a-zA-Z0-9]+-[0-9]+).*|\1|')

  if [[ "$ticket" == "$branch" ]] || ! echo "$ticket" | grep -qE '^.+-[0-9]+$'; then
    echo "jira: branch '$branch' does not contain a Jira ticket number" >&2
    exit 1
  fi

  echo "$ticket"
}

[ $# -lt 1 ] && usage

case "$1" in
  which)
    ticket=$(get_ticket)
    exec acli jira workitem view "$ticket"
    ;;
  browse)
    ticket=$(get_ticket)
    exec acli jira workitem view "$ticket" --web
    ;;
  *)
    usage
    ;;
esac
