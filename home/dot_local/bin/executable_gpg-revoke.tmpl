#!/bin/bash

set -e

OP_ACCOUNT="{{ .onepassword.account_id }}"

echo "Revoking GPG subkey..." >&2

MASTER_KEY_PASSPHRASE=$(op read "op://Personal/GPG Master Key Passphrase/password" \
    --account "$OP_ACCOUNT")

TEMP_GNUPGHOME=$(mktemp -d)
trap "rm -rf '$TEMP_GNUPGHOME'" EXIT
export GNUPGHOME="$TEMP_GNUPGHOME"

op document get "GPG Master Key" --account "$OP_ACCOUNT" \
  | gpg --batch --pinentry-mode loopback --passphrase "$MASTER_KEY_PASSPHRASE" --import

MASTER_KEY_FINGERPRINT=$(gpg --list-secret-keys --with-colons \
  | awk -F: '/^sec/{found=1} found && /^fpr/{print $10; exit}')

echo "" >&2
echo "Select the subkey to revoke with: key N → revkey → save" >&2
echo "" >&2

gpg --pinentry-mode loopback --edit-key "$MASTER_KEY_FINGERPRINT"

echo "Updating master key document in 1Password..." >&2

gpg --batch --pinentry-mode loopback --passphrase "$MASTER_KEY_PASSPHRASE" \
    --armor --export-secret-keys "$MASTER_KEY_FINGERPRINT" \
  | op document edit "GPG Master Key" - --account "$OP_ACCOUNT"

echo "Pushing updated public key to GitHub..." >&2
gpg --armor --export "$MASTER_KEY_FINGERPRINT" | gh gpg-key add -

echo "Done." >&2
